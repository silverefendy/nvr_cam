# ============================================================
# nvr_cam — Environment Variables
# Copy file ini: cp .env.example .env
# Lalu edit nilai-nilainya
# JANGAN commit file .env ke git!
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nvr_cam
DB_USER=nvr_user
DB_PASSWORD=ganti_ini_dengan_password_kuat
DATABASE_URL=postgresql+asyncpg://nvr_user:ganti_ini_dengan_password_kuat@localhost:5432/nvr_cam

# --- Auth ---
JWT_SECRET=ganti_ini_dengan_string_random_panjang_minimal_32_karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Aplikasi ---
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost

# --- Storage ---
RECORDINGS_BASE_PATH=/mnt/recordings
STORAGE_THRESHOLD_PCT=85

# --- Notifikasi Telegram ---
# Buat bot di @BotFather, dapatkan token
# Dapatkan chat_id: kirim pesan ke bot, cek https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=isi_token_bot_telegram_kamu
TELEGRAM_CHAT_ID=isi_chat_id_kamu

# --- Notifikasi Email (opsional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email_kamu@gmail.com
SMTP_PASSWORD=app_password_gmail
SMTP_FROM=nvr@lokasi_kamu.com
NOTIF_EMAIL_TO=penerima@email.com

# --- ZeroTier (opsional, untuk remote access) ---
ZEROTIER_NETWORK_ID=
