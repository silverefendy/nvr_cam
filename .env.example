# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cctv_db
DB_USER=cctv_user
DB_PASSWORD=GANTI_PASSWORD_INI

# ── JWT ───────────────────────────────────────────
JWT_SECRET=GANTI_SECRET_PANJANG_ACAK_INI
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ── Telegram ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
