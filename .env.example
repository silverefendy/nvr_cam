# ── Storage ───────────────────────────────────────
STORAGE_THRESHOLD_PCT=10
HLS_TEMP_DIR=/tmp/hls

# ── App ───────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
