# ============================================================
# nvr_cam — Environment Variables
# Copy file ini: cp .env.example .env
# Lalu edit nilai-nilainya
# JANGAN commit file .env ke git!
# ============================================================

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=nvr_cam
DB_USER=nvr_user
DB_PASSWORD=ganti_ini_dengan_password_kuat

# --- Auth ---
JWT_SECRET=ganti_ini_dengan_string_random_panjang_minimal_32_karakter
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# --- Notifikasi Telegram (opsional) ---
# Buat bot di @BotFather, dapatkan token
# Dapatkan chat_id: kirim pesan ke bot, cek https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notifikasi Email (opsional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Storage ---
STORAGE_THRESHOLD_PCT=10.0
HLS_TEMP_DIR=/tmp/hls
CONFIG_DIR=config

# --- Aplikasi ---
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
