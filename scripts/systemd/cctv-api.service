[Unit]
Description=CCTV NVR — FastAPI Backend
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/cctv
EnvironmentFile=/opt/cctv/.env
ExecStart=/opt/cctv/venv/bin/uvicorn backend.api.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
