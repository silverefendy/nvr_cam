[Unit]
Description=NVR Cam — Recording Engine
After=network.target

[Service]
Type=simple
User=nvr
WorkingDirectory=/opt/nvr_cam
EnvironmentFile=/opt/nvr_cam/.env
ExecStart=/opt/nvr_cam/venv/bin/python -m backend.services.recorder.manager
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
