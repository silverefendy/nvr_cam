[Unit]
Description=CCTV NVR — Recording Engine
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/cctv
EnvironmentFile=/opt/cctv/.env
ExecStart=/opt/cctv/venv/bin/python -m backend.services.recorder.manager
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
